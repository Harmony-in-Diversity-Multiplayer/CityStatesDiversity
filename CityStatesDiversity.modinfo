  </Dependencies>
  <ActionCriteria>
    <Criteria id="Expansion2">
      <RuleSetInUse>RULESET_EXPANSION_2</RuleSetInUse>
    </Criteria>
    <Criteria id="Expansion2_CSE_Ethiopia_ON">
      <RuleSetInUse>RULESET_EXPANSION_2</RuleSetInUse>
      <ConfigurationValueMatches>
        <Group>Game</Group>
        <ConfigurationId>CSE_ETHIOPIA_OPTION</ConfigurationId>
        <Value>1</Value>
      </ConfigurationValueMatches>
    </Criteria>
    <Criteria id="DLC_Ethiopia">
      <RuleSetInUse>RULESET_EXPANSION_2</RuleSetInUse>
      <ModInUse>1B394FE9-23DC-4868-8F0A-5220CB8FB427</ModInUse>
    </Criteria>
  </ActionCriteria>
  <LocalizedText>
    <Text id="LOC_CITY_STATES_DIVERSITY_NAME">
      <en_US>[COLOR_Civ6LightBlue]Harmony in Diversity v2.1: City-States Diversity[ENDCOLOR]</en_US>
      <zh_Hans_CN>[COLOR_Civ6LightBlue]【和而不同 v2.1】城邦多样化[ENDCOLOR]</zh_Hans_CN>
    </Text>
