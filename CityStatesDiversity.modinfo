  <Properties>
    <Name>LOC_CITY_STATES_DIVERSITY_NAME</Name>
    <Description>City-States Diversity</Description>
    <Teaser>City-States Diversity</Teaser>
    <Authors>DeepLogic, 六亿神州尽舜尧, YT, 时代的先驱, 小灰灰, 笑笑</Authors>
    <AffectsSavedGames>1</AffectsSavedGames>
    <CompatibleVersions>1.2,2.0</CompatibleVersions>
  </Properties>
